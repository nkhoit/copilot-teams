{
  "name": "copilot-teams",
  "version": "0.1.0",
  "description": "Agent teams for GitHub Copilot — coordinate multiple AI agents working together",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx src/test-harness.ts",
    "gateway": "tsx src/index.ts"
  },
  "keywords": [
    "copilot",
    "agent",
    "teams",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
